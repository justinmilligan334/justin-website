---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import { Image } from 'astro:assets';

import heroBg from '~/assets/images/photos/DSC_0417.jpeg';
import portrait from '~/assets/images/photos/IMG_9453.JPG';

import photo1 from '~/assets/images/photos/DSC_0417.jpeg';
import photo2 from '~/assets/images/photos/IMG_0420.JPG';
import photo3 from '~/assets/images/photos/IMG_1659.JPG';
import photo4 from '~/assets/images/photos/IMG_1708.JPG';
import photo5 from '~/assets/images/photos/IMG_1782.JPG';
import photo6 from '~/assets/images/photos/IMG_9492.JPG';
import resumeBg from '~/assets/images/photos/IMG_1708.JPG';

const metadata = {
  title: 'Justin Milligan',
  ignoreTitleTemplate: true,
};

const socials = [
  { name: 'LinkedIn', href: 'https://linkedin.com/in/justinmilligan34', icon: 'linkedin' },
  { name: 'Instagram', href: 'https://instagram.com/justin_m34', icon: 'instagram' },
  { name: 'Twitter', href: 'https://x.com/justin_m34', icon: 'twitter' },
  { name: 'Email', href: 'mailto:jmilligan@linkstudio.ai', icon: 'email' },
];

const photos = [
  { src: photo1, alt: 'Sunset over a lake' },
  { src: photo2, alt: 'Golden hour from a mountain summit' },
  { src: photo6, alt: 'Niagara Falls with a friend' },
  { src: photo3, alt: 'Mountain goat on an alpine ridge' },
  { src: photo4, alt: 'Alpine lake beneath towering peaks' },
  { src: photo5, alt: 'Chipmunk snacking on a rock' },
];

---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '#' },
        { text: 'Link Studio', href: '#work' },
        { text: 'Photos', href: '#photos' },
        { text: 'Projects', href: '#projects' },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- ============================================ -->
  <!-- HERO                                          -->
  <!-- ============================================ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background image — parallax target -->
    <div id="hero-bg" class="absolute inset-0 will-change-transform">
      <Image
        src={heroBg}
        alt="Lake sunset"
        class="w-full h-full object-cover"
        widths={[800, 1200, 1800]}
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-6 max-w-3xl">
      <!-- Circular portrait -->
      <div class="mb-8 flex justify-center">
        <div class="w-36 h-36 sm:w-44 sm:h-44 rounded-full overflow-hidden border-[3px] border-white/20 shadow-2xl shadow-black/40">
          <Image
            src={portrait}
            alt="Justin Milligan"
            class="w-full h-full object-cover"
            widths={[200, 400]}
            loading="eager"
          />
        </div>
      </div>

      <p class="text-xs uppercase tracking-[0.4em] text-white/50 mb-5 font-sans">
        personal site
      </p>
      <h1 class="hero-gradient-name text-5xl sm:text-6xl md:text-7xl font-heading font-bold leading-[0.92] mb-10 italic">
        Justin<br />Milligan
      </h1>

      <!-- Currently at badge -->
      <a
        href="https://www.linkventures.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all duration-300 mb-10 group"
      >
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        <span class="text-xs uppercase tracking-[0.2em] text-white/60 group-hover:text-white/80 transition-colors">Currently with</span>
        <span class="text-sm font-semibold text-white/90 tracking-wide">Link Ventures</span>
      </a>

      <!-- Social icons -->
      <div class="flex items-center justify-center gap-5">
        {socials.map((s) => (
          <a
            href={s.href}
            target={s.icon === 'email' ? undefined : '_blank'}
            rel="noopener noreferrer"
            class="text-white/40 hover:text-amber-200 transition-colors duration-300"
            aria-label={s.name}
          >
            {s.icon === 'linkedin' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            )}
            {s.icon === 'instagram' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            )}
            {s.icon === 'twitter' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            )}
            {s.icon === 'email' && (
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            )}
          </a>
        ))}
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-white/30" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- LINK + DOCUMENTS                             -->
  <!-- ============================================ -->
  <section id="work" class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-5 items-stretch">
        <div
          class="relative overflow-hidden rounded-[2rem] border border-white/8 bg-gradient-to-br from-stone-950 via-stone-900 to-black p-8 sm:p-10 animate-on-scroll"
          style="transition-delay: 0s"
        >
          <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 40px 40px;"></div>
          <div class="absolute -top-10 right-0 h-40 w-40 rounded-full bg-amber-300/10 blur-3xl"></div>
          <div class="absolute bottom-0 left-0 h-32 w-32 rounded-full bg-emerald-300/10 blur-3xl"></div>

          <div class="relative z-10 max-w-xl">
            <p class="text-[10px] uppercase tracking-[0.32em] text-amber-300/60 mb-4">Link Studio</p>
            <h2 class="text-4xl sm:text-5xl font-heading font-bold italic text-white/95 leading-tight mb-5">
              Working with AI founders in Cambridge.
            </h2>
            <p class="text-base text-white/65 font-light leading-relaxed max-w-lg mb-8">
              I spend my time meeting AI founders, helping facilitate the leap from idea to company inside Link Studio, and trying to make the world a little better through my work.
            </p>

            <a
              href="mailto:jmilligan@linkstudio.ai"
              class="inline-flex items-center gap-2 rounded-full border border-amber-300/25 bg-amber-300/10 px-5 py-3 text-sm font-medium text-amber-100 transition-colors hover:bg-amber-300/15"
            >
              Reach out about building with Link Studio
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 17.25 16.5 8.25M16.5 8.25H9.75m6.75 0V15" /></svg>
            </a>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-1 gap-5">
          <a
            href="/files/senior-thesis-justin-milligan.pdf"
            target="_blank"
            class="group relative overflow-hidden rounded-[1.75rem] min-h-[240px] animate-on-scroll"
            style="transition-delay: 0.1s"
          >
            <Image
              src={photo2}
              alt=""
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              widths={[500, 800]}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/20"></div>
            <div class="relative z-10 flex h-full flex-col justify-end p-7">
              <p class="text-[10px] uppercase tracking-[0.28em] text-white/45 mb-2">Senior Thesis</p>
              <h3 class="text-2xl font-heading font-bold italic text-white leading-tight mb-3 group-hover:text-amber-200 transition-colors">
                Rethinking the Arc
              </h3>
              <p class="text-xs text-white/55 leading-relaxed mb-5 max-w-sm">
                An econometric and game-theoretical analysis of the NBA's three-point reliance and proposed rule changes.
              </p>
              <span class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-wider text-amber-300 group-hover:text-amber-200 transition-colors">
                Read PDF
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
              </span>
            </div>
          </a>

          <a
            href="/files/justin-milligan-resume.docx"
            target="_blank"
            class="group relative overflow-hidden rounded-[1.75rem] min-h-[240px] animate-on-scroll"
            style="transition-delay: 0.18s"
          >
            <Image
              src={resumeBg}
              alt=""
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              widths={[500, 800]}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10"></div>
            <div class="absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 28px 28px;"></div>
            <div class="relative z-10 flex h-full flex-col justify-end p-7">
              <p class="text-[10px] uppercase tracking-[0.28em] text-white/45 mb-2">Resume</p>
              <h3 class="text-2xl font-heading font-bold italic text-white leading-tight mb-3 group-hover:text-amber-200 transition-colors">
                For the sake of formality
              </h3>
              <p class="text-xs text-white/55 leading-relaxed mb-5 max-w-sm">
                My life on a piece of paper.
              </p>
              <span class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-wider text-amber-300 group-hover:text-amber-200 transition-colors">
                Download
                <svg class="w-3.5 h-3.5 group-hover:translate-y-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- PHOTO GALLERY — 3x2 grid + lightbox          -->
  <!-- ============================================ -->
  <section id="photos" class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 sm:mb-14 animate-on-scroll">
        <p class="text-xs uppercase tracking-[0.3em] text-muted mb-3">Photos</p>
        <h2 class="text-4xl sm:text-5xl font-heading font-bold italic mb-5">Some of my favorites</h2>
        <p class="text-base text-muted max-w-md mx-auto font-light leading-relaxed">
          I bought a camera in 2022. I have successfully taken 6 good pictures.
        </p>
      </div>

      <!-- 3x2 grid — click to open lightbox -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
        {photos.map((photo, i) => (
          <div
            class="overflow-hidden rounded-lg group aspect-[4/3] cursor-pointer lightbox-trigger animate-on-scroll"
            style={`transition-delay: ${i * 0.08}s`}
          >
            <Image
              src={photo.src}
              alt={photo.alt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              widths={[400, 700]}
              loading={i < 3 ? "eager" : "lazy"}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- PROJECTS                                      -->
  <!-- ============================================ -->
  <section id="projects" class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12 animate-on-scroll">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-muted mb-3">Apps and tools</p>
          <h2 class="text-4xl sm:text-5xl font-heading font-bold italic">Things I'm building for fun</h2>
        </div>
        <p class="text-base text-muted max-w-md font-light leading-relaxed sm:text-right">
          Some projects for fun.
        </p>
      </div>

      <div class="grid lg:grid-cols-[1.08fr_0.92fr] gap-6">
        <a
          href="https://wish-ten-mu.vercel.app"
          target="_blank"
          rel="noopener"
          class="group relative overflow-hidden rounded-[2rem] min-h-[420px] border border-white/8 bg-[radial-gradient(circle_at_top_left,_rgba(251,191,36,0.18),_transparent_32%),linear-gradient(135deg,_rgba(24,24,27,1),_rgba(10,10,11,1))] p-8 sm:p-9 animate-on-scroll"
          style="transition-delay: 0s"
        >
          <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 34px 34px;"></div>
          <div class="absolute -right-12 top-8 text-[10rem] font-heading italic leading-none text-white/[0.04] transition-transform duration-700 group-hover:translate-x-[-0.5rem]">W</div>
          <div class="relative z-10 flex h-full flex-col justify-between">
            <div>
              <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-[10px] uppercase tracking-[0.24em] text-emerald-300">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-300 animate-pulse"></span>
                Live
              </span>
            </div>
            <div>
              <p class="text-[10px] uppercase tracking-[0.28em] text-white/35 mb-3">Habit tracking</p>
              <h3 class="text-4xl sm:text-5xl font-heading font-bold italic text-white mb-4">Wish</h3>
              <p class="max-w-md text-sm text-white/60 leading-relaxed mb-6">
                Track daily habits, mood, and WHOOP data in one place. Built to make the invisible parts of a routine easier to see.
              </p>
              <span class="inline-flex items-center gap-2 text-sm font-medium text-amber-200 group-hover:text-white transition-colors">
                Open app
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
              </span>
            </div>
          </div>
        </a>

        <div class="grid gap-6">
          <a
            href="/pricerx"
            class="group relative overflow-hidden rounded-[2rem] min-h-[200px] border border-white/8 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.16),_transparent_28%),linear-gradient(145deg,_rgba(17,24,39,1),_rgba(7,10,15,1))] p-7 animate-on-scroll"
            style="transition-delay: 0.1s"
          >
            <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 30px 30px;"></div>
            <div class="relative z-10 flex h-full flex-col justify-between">
              <span class="inline-flex w-fit items-center gap-1.5 rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1 text-[10px] uppercase tracking-[0.24em] text-sky-200">
                Live
              </span>
              <div>
                <p class="text-[10px] uppercase tracking-[0.28em] text-white/35 mb-3">Helping make treatment affordable</p>
                <h3 class="text-3xl font-heading font-bold italic text-white mb-3">PriceRX</h3>
                <p class="text-sm text-white/60 leading-relaxed">
                  Look up real drug prices using NADAC and Cost Plus Drugs data so the actual numbers are easier to compare.
                </p>
              </div>
            </div>
          </a>

          <div
            class="relative overflow-hidden rounded-[2rem] min-h-[200px] border border-white/8 bg-[linear-gradient(135deg,_rgba(24,24,27,1),_rgba(13,13,14,1))] p-7 animate-on-scroll"
            style="transition-delay: 0.18s"
          >
            <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 30px 30px;"></div>
            <div class="absolute bottom-0 right-0 h-32 w-32 rounded-full bg-emerald-400/10 blur-3xl"></div>
            <div class="relative z-10 flex h-full flex-col justify-between">
              <span class="inline-flex w-fit items-center gap-1.5 rounded-full border border-white/12 bg-white/5 px-3 py-1 text-[10px] uppercase tracking-[0.24em] text-white/40">
                In progress
              </span>
              <div>
                <p class="text-[10px] uppercase tracking-[0.28em] text-white/35 mb-3">Next up</p>
                <h3 class="text-3xl font-heading font-bold italic text-white mb-3">More soon</h3>
                <p class="text-sm text-white/60 leading-relaxed">Will update soon!</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ============================================ -->
  <!-- FOOTER / CONNECT                              -->
  <!-- ============================================ -->
  <section class="py-16 sm:py-20 border-t border-gray-200 dark:border-white/5">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold italic mb-4">Say hello</h2>
      <p class="text-muted mb-8">
        <a href="mailto:jmilligan@linkstudio.ai" class="underline decoration-amber-400/50 hover:decoration-amber-400 underline-offset-4 transition-colors">jmilligan@linkstudio.ai</a>
      </p>
      <div class="flex items-center justify-center gap-6">
        {socials.filter(s => s.icon !== 'email').map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-muted hover:text-amber-700 dark:hover:text-amber-400 transition-colors underline underline-offset-4 decoration-transparent hover:decoration-current"
          >
            {s.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- LIGHTBOX OVERLAY                              -->
  <!-- ============================================ -->
  <div id="lightbox" class="fixed inset-0 z-[9999] bg-black/95 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 cursor-pointer">
    <button id="lightbox-close" class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white/60 hover:text-white transition-all" aria-label="Close">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <img id="lightbox-img" class="max-w-[92vw] max-h-[88vh] object-contain rounded-lg shadow-2xl transition-transform duration-300 scale-95" alt="" />
  </div>
</Layout>

<!-- ============================================ -->
<!-- GLOBAL STYLES                                 -->
<!-- ============================================ -->
<style is:global>
  /* ── Scroll-triggered animations ── */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Hero gradient-animated name ── */
  .hero-gradient-name {
    background: linear-gradient(
      120deg,
      #f5f5f4 0%,
      #e7d1a0 28%,
      #ffffff 50%,
      #dcc28a 72%,
      #f5f5f4 100%
    );
    background-size: 220% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: hero-gradient-shift 12s ease-in-out infinite;
  }
  @keyframes hero-gradient-shift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* ── Lightbox active state ── */
  #lightbox.is-active {
    opacity: 1;
    pointer-events: auto;
  }
  #lightbox.is-active #lightbox-img {
    transform: scale(1);
  }
</style>

<!-- ============================================ -->
<!-- CLIENT-SIDE SCRIPTS                           -->
<!-- ============================================ -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {

    /* ── 1. Scroll-triggered fade-in animations ── */
    var animEls = document.querySelectorAll('.animate-on-scroll');
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      animEls.forEach(function (el) { observer.observe(el); });
    } else {
      /* Fallback: show everything immediately */
      animEls.forEach(function (el) { el.classList.add('is-visible'); });
    }

    /* ── 2. Hero parallax ── */
    var heroBg = document.getElementById('hero-bg');
    if (heroBg) {
      var ticking = false;
      window.addEventListener('scroll', function () {
        if (!ticking) {
          requestAnimationFrame(function () {
            var y = window.scrollY;
            if (y < window.innerHeight * 1.2) {
              heroBg.style.transform = 'translateY(' + (y * 0.35) + 'px)';
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }

    /* ── 3. Photo lightbox ── */
    var lightbox = document.getElementById('lightbox');
    var lightboxImg = document.getElementById('lightbox-img');

    document.querySelectorAll('.lightbox-trigger').forEach(function (el) {
      el.addEventListener('click', function () {
        var img = el.querySelector('img');
        if (img && lightbox && lightboxImg) {
          /* Use the largest available src */
          var src = img.currentSrc || img.src;
          lightboxImg.src = src;
          lightboxImg.alt = img.alt || '';
          lightbox.classList.add('is-active');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    function closeLightbox() {
      if (lightbox) {
        lightbox.classList.remove('is-active');
        document.body.style.overflow = '';
      }
    }

    if (lightbox) {
      lightbox.addEventListener('click', closeLightbox);
    }

    /* Close on Escape key */
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeLightbox();
    });

  });
</script>
